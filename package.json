{
  "name": "superchart",
  "version": "0.0.1",
  "type": "module",
  "description": "Advanced Charting Library UI for React",
  "main": "./dist/superchart.cjs.js",
  "module": "./dist/superchart.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/superchart.es.js",
      "require": "./dist/superchart.cjs.js"
    },
    "./styles": "./dist/superchart.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "pnpm run build:lib"
  },
  "dependencies": {
    "chroma-js": "^3.2.0",
    "klinecharts": "workspace:*",
    "lodash": "^4.17.23"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/chroma-js": "^3.1.1",
    "@types/lodash": "^4.17.23",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "less": "^4.5.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/altrady/superchart.git"
  },
  "keywords": [
    "react",
    "chart",
    "trading",
    "kline",
    "candlestick",
    "ui-library"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
