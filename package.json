{
  "name": "superchart",
  "version": "0.0.1",
  "type": "module",
  "description": "Advanced Charting Library UI for React",
  "main": "./dist/superchart.cjs.js",
  "module": "./dist/superchart.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/superchart.es.js",
      "require": "./dist/superchart.cjs.js"
    },
    "./styles": "./dist/superchart.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "src/lib/extension/index.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build:core": "tsc -b && vite build",
    "build:dts": "dts-bundle-generator --config dts-bundle-generator.config.json",
    "build": "pnpm run build:core && pnpm run build:dts",
    "build:lib": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "chroma-js": "^3.2.0",
    "klinecharts": "workspace:*",
    "lodash": "^4.17.23"
  },
  "peerDependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/search": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@lezer/highlight": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@codemirror/autocomplete": {
      "optional": true
    },
    "@codemirror/commands": {
      "optional": true
    },
    "@codemirror/language": {
      "optional": true
    },
    "@codemirror/lint": {
      "optional": true
    },
    "@codemirror/search": {
      "optional": true
    },
    "@codemirror/state": {
      "optional": true
    },
    "@codemirror/view": {
      "optional": true
    },
    "@codemirror/theme-one-dark": {
      "optional": true
    },
    "@lezer/highlight": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/lint": "^6.9.3",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@codemirror/view": "^6.35.0",
    "@eslint/js": "^9.39.1",
    "@lezer/highlight": "^1.2.0",
    "@storybook/react": "^10.2.13",
    "@storybook/react-vite": "^10.2.13",
    "@types/chroma-js": "^3.1.1",
    "@types/lodash": "^4.17.23",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "coinrayjs": "^2.0.10",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "less": "^4.5.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.2.13",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/altrady/superchart.git"
  },
  "keywords": [
    "react",
    "chart",
    "trading",
    "kline",
    "candlestick",
    "ui-library"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
