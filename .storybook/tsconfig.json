{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true,
    "strict": true,
    "baseUrl": "..",
    "paths": {
      "@superchart/*": ["src/lib/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
